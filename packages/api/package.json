{
  "name": "@sakamichi48/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "data:snapshot": "tsc -p tsconfig.json && node dist/scripts/build-static-data.js",
    "data:check": "tsc -p tsconfig.json && node dist/scripts/validate-static-data.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "drizzle-orm": "^0.44.6",
    "fastify": "^5.6.1",
    "postgres": "^3.4.7",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
